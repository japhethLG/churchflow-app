{
	"name": "churchflow-app",
	"version": "1.0.0",
	"description": "ChurchFlow - Multi-tenant church management system",
	"private": true,
	"scripts": {
		"dev": "bash scripts/wait-for-api.sh && NODE_OPTIONS='--max-old-space-size=4096' next dev",
		"dev:test": "NODE_OPTIONS='--max-old-space-size=4096' dotenv -e .env.development.local -- next dev",
		"build": "dotenv -e .env.production -- next build",
		"build:test": "dotenv -e .env.development.local -- next build",
		"start": "dotenv -e .env.production -- next start -p 3002",
		"start:test": "dotenv -e .env.development.local -- next start",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"check": "node scripts/enforce-ui-primitives.mjs && node scripts/check-invalidation-paths.mjs && biome check --write --unsafe .",
		"check:staged": "node scripts/enforce-ui-primitives.mjs && lint-staged",
		"api:types": "openapi-typescript http://localhost:8000/api-docs-json -o src/lib/api/schema.d.ts",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,mjs,cjs,json,css}": [
			"biome check --write --unsafe --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/react-query": "^5.100.1",
		"@tanstack/react-query-devtools": "^5.100.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.20",
		"firebase": "^12.12.1",
		"firebase-admin": "^13.8.0",
		"lucide-react": "^1.11.0",
		"next": "^16.2.4",
		"openapi-fetch": "^0.17.0",
		"react": "^19.2.5",
		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.74.0",
		"recharts": "^3.8.1",
		"shadcn": "^4.5.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@serwist/turbopack": "^9.5.11",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"dotenv-cli": "^11.0.0",
		"esbuild": "^0.28.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"openapi-typescript": "^7.13.0",
		"server-only": "^0.0.1",
		"serwist": "^9.5.11",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"openapi-typescript": {
			"typescript": "$typescript"
		}
	}
}
