{
  "name": "churchflow-app",
  "version": "1.0.0",
  "description": "ChurchFlow - Multi-tenant church management system",
  "private": true,
  "scripts": {
    "dev": "bash scripts/wait-for-api.sh && next dev",
    "dev:test": "dotenv -e .env.development.local -- next dev",
    "build": "dotenv -e .env.production -- next build",
    "build:test": "dotenv -e .env.development.local -- next build",
    "start": "dotenv -e .env.production -- next start -p 3002",
    "start:test": "dotenv -e .env.development.local -- next start",
    "typecheck": "tsc --noEmit",
    "api:types": "openapi-typescript http://localhost:8000/api-docs-json -o src/lib/api/schema.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-query-devtools": "^5.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^11.0.0",
    "openapi-typescript": "^7.13.0",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
